# ═══════════════════════════════════════════════════
# NÖRA - Bilişsel Tarama AI Ajanı
# Merkezi Ortam Değişkenleri (Single Source of Truth)
# ═══════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# cp .env.example .env

# ─── Sunucu Ayarları ───
PORT=3001
NODE_ENV=development

# ─── Veritabanı ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cognitive_agent?schema=public

# ─── JWT ───
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Google Cloud ───
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Gemini Model Ayarları ───
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
LIVE_VOICE_NAME=Puck

# ─── Hikaye Üretim (Test 2) ───
GEMINI_STORY_MODEL=gemini-3.1-flash-lite-preview

# ─── Test 1 Otomatik Bitiriş (opsiyonel tuning) ───
# Kullanıcı uzun süre sessiz kaldığında Test 1 timer'ını otomatik durdurmak için
# eşikler (milisaniye).
TEST1_INACTIVITY_WARN_MS=10000
TEST1_INACTIVITY_STOP_MS=16000
TEST1_AUTO_STOP_MIN_ELAPSED_MS=20000

# ─── Görsel Üretim - Imagen 4 (Test 3) ───
# Opsiyonel: Ayarlanmazsa GOOGLE_API_KEY kullanılır
GEMINI_IMAGE_API_KEY=
IMAGEN_MODEL=imagen-4.0-fast-generate-001

# ─── Frontend (CORS + Vite) ───
FRONTEND_URL=http://localhost:5173
VITE_DEV_PORT=5173
VITE_API_URL=http://localhost:3001/api
# Opsiyonel: vermezsen VITE_API_URL'den otomatik türetilir (ws/wss + /ws/live)
VITE_WS_URL=
VITE_GOOGLE_API_KEY=
VITE_GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
VITE_LIVE_VOICE_NAME=Puck
